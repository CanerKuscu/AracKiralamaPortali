@{
    ViewData["Title"] = "Arac Detay";
    var vehicleId = ViewData["VehicleId"];
}

<div class="row" id="vehicleDetail">
    <div class="col-md-6" id="vehicleImage"></div>
    <div class="col-md-6">
        <div class="card shadow">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0" id="vehicleTitle"></h4>
            </div>
            <div class="card-body">
                <table class="table">
                    <tr><th>Plaka</th><td id="vPlate"></td></tr>
                    <tr><th>Marka</th><td id="vBrand"></td></tr>
                    <tr><th>Model</th><td id="vModel"></td></tr>
                    <tr><th>Yil</th><td id="vYear"></td></tr>
                    <tr><th>Renk</th><td id="vColor"></td></tr>
                    <tr><th>Yakit Tipi</th><td id="vFuel"></td></tr>
                    <tr><th>Vites</th><td id="vTransmission"></td></tr>
                    <tr><th>KM</th><td id="vMileage"></td></tr>
                    <tr><th>Yolcu Kapasitesi</th><td id="vPassenger"></td></tr>
                    <tr><th>Bagaj Kapasitesi</th><td id="vLuggage"></td></tr>
                    <tr><th>Gunluk Fiyat</th><td id="vPrice"></td></tr>
                    <tr><th>Haftalik Fiyat</th><td id="vWeekly"></td></tr>
                    <tr><th>Aylik Fiyat</th><td id="vMonthly"></td></tr>
                    <tr><th>Durum</th><td id="vStatus"></td></tr>
                    <tr><th>Aciklama</th><td id="vDescription"></td></tr>
                </table>
            </div>
        </div>

        <div class="card shadow mt-3" id="reservationCard" style="display:none;">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0"><i class="fas fa-calendar-plus"></i> Rezervasyon Yap</h5>
            </div>
            <div class="card-body">
                <form id="reservationForm">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Baslangic Tarihi</label>
                            <input type="date" class="form-control" id="startDate" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Bitis Tarihi</label>
                            <input type="date" class="form-control" id="endDate" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Alis Yeri</label>
                            <input type="text" class="form-control" id="pickupLocation" placeholder="Sube / Konum" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Teslim Yeri</label>
                            <input type="text" class="form-control" id="dropoffLocation" placeholder="Sube / Konum" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label"><strong>Ek Hizmetler</strong></label>
                        <div id="additionalServicesList"></div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Not</label>
                        <textarea class="form-control" id="notes" rows="2"></textarea>
                    </div>
                    <div class="mb-3">
                        <strong>Tahmini Toplam: <span id="estimatedTotal" class="text-success">0 TL</span></strong>
                        <br/><small class="text-muted">Depozito: <span id="estimatedDeposit">0 TL</span></small>
                    </div>
                    <button type="submit" class="btn btn-success w-100">Rezervasyon Yap</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var vehicleId = @vehicleId;
    var dailyPrice = 0;
    var services = [];

    $(document).ready(function () {
        var today = new Date().toISOString().split('T')[0];
        $("#startDate").attr("min", today);
        $("#endDate").attr("min", today);

        $.ajax({
            url: apiBaseUrl + "/Vehicles/" + vehicleId,
            type: "GET",
            success: function (v) {
                dailyPrice = v.dailyPrice;
                $("#vehicleTitle").text(v.brandName + " " + v.model + " - " + v.plate);
                $("#vPlate").text(v.plate);
                $("#vBrand").text(v.brandName);
                $("#vModel").text(v.model);
                $("#vYear").text(v.year);
                $("#vColor").text(v.color);
                $("#vFuel").text(v.fuelType);
                $("#vTransmission").text(v.transmissionType);
                $("#vMileage").text(v.mileage);
                $("#vPassenger").text(v.passengerCapacity);
                $("#vLuggage").text(v.luggageCapacity);
                $("#vPrice").html('<strong class="text-success">' + v.dailyPrice + ' TL / Gun</strong>');
                $("#vWeekly").text(v.weeklyPrice ? v.weeklyPrice + " TL" : "-");
                $("#vMonthly").text(v.monthlyPrice ? v.monthlyPrice + " TL" : "-");
                $("#vDescription").text(v.description || "-");
                var statusMap = {"Available":"Musait","Rented":"Kirada","Maintenance":"Bakimda","Damaged":"Hasarli"};
                var statusColor = {"Available":"success","Rented":"warning","Maintenance":"info","Damaged":"danger"};
                $("#vStatus").html('<span class="badge bg-' + (statusColor[v.vehicleStatus]||"secondary") + '">' + (statusMap[v.vehicleStatus]||v.vehicleStatus) + '</span>');
                if (v.vehicleStatus === "Available") {
                    if (isLoggedIn()) $("#reservationCard").show();
                }
                if (v.imageUrl) $("#vehicleImage").html('<img src="' + v.imageUrl + '" class="img-fluid rounded shadow" />');
                else $("#vehicleImage").html('<div class="bg-secondary text-white d-flex align-items-center justify-content-center rounded" style="height:350px;"><i class="fas fa-car fa-5x"></i></div>');
            }
        });

        $.ajax({
            url: apiBaseUrl + "/AdditionalServices",
            type: "GET",
            success: function (data) {
                services = data;
                var html = "";
                $.each(data, function (i, s) {
                    if (s.isActive) {
                        html += '<div class="form-check"><input class="form-check-input svc-check" type="checkbox" value="' + s.id + '" data-price="' + s.price + '" id="svc' + s.id + '" />';
                        html += '<label class="form-check-label" for="svc' + s.id + '">' + s.name + ' (' + s.price + ' TL/Gun)</label></div>';
                    }
                });
                if (!html) html = '<small class="text-muted">Ek hizmet bulunmamaktadir.</small>';
                $("#additionalServicesList").html(html);
            }
        });
    });

    function calcTotal() {
        var s = new Date($("#startDate").val()), e = new Date($("#endDate").val());
        if (s && e && e > s) {
            var days = Math.ceil((e - s) / (1000 * 60 * 60 * 24));
            var svcTotal = 0;
            $(".svc-check:checked").each(function () { svcTotal += parseFloat($(this).data("price")); });
            var total = (dailyPrice + svcTotal) * days;
            $("#estimatedTotal").text(total + " TL");
            $("#estimatedDeposit").text((dailyPrice * 3) + " TL");
        }
    }

    $("#startDate, #endDate").change(calcTotal);
    $(document).on("change", ".svc-check", calcTotal);

    $("#reservationForm").submit(function (e) {
        e.preventDefault();
        if (!isLoggedIn()) { window.location.href = "/Auth/Login"; return; }
        var selectedSvcs = [];
        $(".svc-check:checked").each(function () { selectedSvcs.push(parseInt($(this).val())); });
        $.ajax({
            url: apiBaseUrl + "/Reservations",
            type: "POST",
            contentType: "application/json",
            data: JSON.stringify({
                startDate: $("#startDate").val(), endDate: $("#endDate").val(),
                notes: $("#notes").val(), vehicleId: vehicleId,
                pickupLocation: $("#pickupLocation").val(), dropoffLocation: $("#dropoffLocation").val(),
                additionalServiceIds: selectedSvcs
            }),
            success: function (res) {
                showAlert("Rezervasyon olusturuldu! Toplam: " + res.totalPrice + " TL, Depozito: " + res.depositAmount + " TL", "success");
                $("#reservationForm")[0].reset();
                $("#estimatedTotal").text("0 TL");
                $("#estimatedDeposit").text("0 TL");
            },
            error: function (xhr) {
                var msg = "Rezervasyon olusturulamadi.";
                if (xhr.responseJSON && xhr.responseJSON.message) msg = xhr.responseJSON.message;
                showAlert(msg, "danger");
            }
        });
    });
</script>
}
