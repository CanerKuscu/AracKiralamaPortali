@{
    ViewData["Title"] = "Arac Detay";
    var vehicleId = ViewData["VehicleId"];
}

<style>
    .vehicle-detail-page .vehicle-top-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #303030;
    }

    .vehicle-detail-page .vehicle-gallery-card,
    .vehicle-detail-page .vehicle-price-card,
    .vehicle-detail-page .vehicle-spec-card {
        border: 1px solid #e5e5e5;
        background: #fff;
        border-radius: 8px;
        padding: 16px;
    }

    .vehicle-main-image {
        width: 100%;
        height: 420px;
        object-fit: cover;
        border-radius: 6px;
        border: 1px solid #ddd;
    }

    .vehicle-thumbs {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 12px;
    }

    .vehicle-thumbs img {
        width: 88px;
        height: 66px;
        object-fit: cover;
        border-radius: 4px;
        border: 1px solid #d9d9d9;
        cursor: pointer;
    }

    .vehicle-title {
        font-size: 1.2rem;
        font-weight: 700;
        margin-bottom: 14px;
        color: #2f2f2f;
    }

    .vehicle-price {
        display: flex;
        align-items: baseline;
        gap: 8px;
        color: #1f6fd9;
        font-weight: 700;
    }

    .vehicle-price span {
        font-size: 2rem;
        line-height: 1;
    }

    .vehicle-detail-page th {
        width: 42%;
        color: #202020;
    }
</style>

<div class="vehicle-detail-page" id="vehicleDetail">
    <div class="mb-3">
        <div class="text-muted small">Vasita &gt; Kiralik Araclar &gt; Arac Detay</div>
        <div class="vehicle-top-title" id="topVehicleTitle"></div>
    </div>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="vehicle-gallery-card shadow-sm">
                <div id="vehicleImage"></div>
                <div id="vehicleThumbs" class="vehicle-thumbs"></div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="vehicle-price-card shadow-sm mb-3">
                <div class="vehicle-price" id="vPrice"></div>
                <div class="vehicle-location text-muted"><i class="fas fa-location-dot"></i> Antalya / Muratpasa</div>
            </div>

            <div class="vehicle-spec-card shadow-sm">
                <h4 class="vehicle-title" id="vehicleTitle"></h4>
                <table class="table table-sm align-middle mb-0">
                    <tr><th>Plaka</th><td id="vPlate"></td></tr>
                    <tr><th>Marka</th><td id="vBrand"></td></tr>
                    <tr><th>Model</th><td id="vModel"></td></tr>
                    <tr><th>Yil</th><td id="vYear"></td></tr>
                    <tr><th>Renk</th><td id="vColor"></td></tr>
                    <tr><th>Yakit Tipi</th><td id="vFuel"></td></tr>
                    <tr><th>Vites</th><td id="vTransmission"></td></tr>
                    <tr><th>KM</th><td id="vMileage"></td></tr>
                    <tr><th>Yolcu Kapasitesi</th><td id="vPassenger"></td></tr>
                    <tr><th>Bagaj Kapasitesi</th><td id="vLuggage"></td></tr>
                    <tr><th>Haftalik Fiyat</th><td id="vWeekly"></td></tr>
                    <tr><th>Aylik Fiyat</th><td id="vMonthly"></td></tr>
                    <tr><th>Durum</th><td id="vStatus"></td></tr>
                    <tr><th>Aciklama</th><td id="vDescription"></td></tr>
                </table>
            </div>

            <div class="mt-3" id="reservationAction" style="display:none;">
                <a href="#" id="reservationButton" class="btn btn-warning btn-lg w-100 fw-bold">
                    <i class="fas fa-calendar-check"></i> Araci Rezervasyon Yap
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var vehicleId = @vehicleId;

    function setMainImage(url) {
        if (!url) {
            $("#vehicleImage").html('<div class="bg-secondary text-white d-flex align-items-center justify-content-center rounded" style="height:420px;"><i class="fas fa-car fa-5x"></i></div>');
            return;
        }

        $("#vehicleImage").html('<img src="' + url + '" class="vehicle-main-image" />');
    }

    function renderGallery(v) {
        var rawImages = (v.imageUrls && v.imageUrls.length > 0) ? v.imageUrls : (v.imageUrl ? [v.imageUrl] : []);
        var images = rawImages.map(function (img) { return resolveApiFileUrl(img); }).filter(function (img) { return !!img; });

        if (images.length === 0) {
            setMainImage(null);
            $("#vehicleThumbs").empty();
            return;
        }

        setMainImage(images[0]);

        var thumbsHtml = "";
        $.each(images, function (i, img) {
            thumbsHtml += '<img src="' + img + '" alt="Arac ' + (i + 1) + '" data-img="' + img + '" />';
        });
        $("#vehicleThumbs").html(thumbsHtml);
    }

    $(document).on("click", "#vehicleThumbs img", function () {
        setMainImage($(this).data("img"));
    });

    $(document).ready(function () {
        $.ajax({
            url: apiBaseUrl + "/Vehicles/" + vehicleId,
            type: "GET",
            success: function (v) {
                var fullTitle = (v.brandName + " " + v.model + " / " + v.plate).toUpperCase();
                $("#vehicleTitle").text(fullTitle);
                $("#topVehicleTitle").text(fullTitle);

                $("#vPlate").text(v.plate);
                $("#vBrand").text(v.brandName);
                $("#vModel").text(v.model);
                $("#vYear").text(v.year);
                $("#vColor").text(v.color || "-");
                $("#vFuel").text(v.fuelType || "-");
                $("#vTransmission").text(v.transmissionType || "-");
                $("#vMileage").text(v.mileage || "-");
                $("#vPassenger").text(v.passengerCapacity || "-");
                $("#vLuggage").text(v.luggageCapacity || "-");

                $("#vPrice").html('<span>' + v.dailyPrice + ' TL</span><small>/ Gun</small>');
                $("#vWeekly").text(v.weeklyPrice ? v.weeklyPrice + " TL" : "-");
                $("#vMonthly").text(v.monthlyPrice ? v.monthlyPrice + " TL" : "-");
                $("#vDescription").text(v.description || "-");

                var statusMap = { "Available": "Musait", "Rented": "Kirada", "Maintenance": "Bakimda", "Damaged": "Hasarli" };
                var statusColor = { "Available": "success", "Rented": "warning", "Maintenance": "info", "Damaged": "danger" };
                $("#vStatus").html('<span class="badge bg-' + (statusColor[v.vehicleStatus] || "secondary") + '">' + (statusMap[v.vehicleStatus] || v.vehicleStatus) + '</span>');

                if (v.vehicleStatus === "Available") {
                    $("#reservationAction").show();
                    if (isLoggedIn()) {
                        $("#reservationButton").attr("href", "/Reservation/Create?vehicleId=" + vehicleId);
                    } else {
                        $("#reservationButton").attr("href", "/Auth/Login");
                    }
                }

                renderGallery(v);
            }
        });
    });
</script>
}
