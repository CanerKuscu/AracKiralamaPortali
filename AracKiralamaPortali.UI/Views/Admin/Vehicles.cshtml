@{
    ViewData["Title"] = "Arac Yonetimi";
}

<h2><i class="fas fa-car"></i> Arac Yonetimi</h2>

<button class="btn btn-primary mb-3" onclick="openAddModal()"><i class="fas fa-plus"></i> Yeni Arac</button>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr><th>ID</th><th>Plaka</th><th>Marka</th><th>Model</th><th>Yil</th><th>Renk</th><th>Yakit</th><th>Vites</th><th>Gunluk Fiyat</th><th>Durum</th><th>Islem</th></tr>
        </thead>
        <tbody id="vehicleList"></tbody>
    </table>
</div>

<div class="modal fade" id="vehicleModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="vehicleModalTitle"></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="vehicleForm">
                    <input type="hidden" id="vehicleId" />
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Plaka</label>
                            <input type="text" class="form-control" id="vPlate" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Marka</label>
                            <select class="form-select" id="vBrandId" required></select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Model</label>
                            <input type="text" class="form-control" id="vModel" required />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Yil</label>
                            <input type="number" class="form-control" id="vYear" required />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Renk</label>
                            <input type="text" class="form-control" id="vColor" required />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Gunluk Fiyat</label>
                            <input type="number" step="0.01" class="form-control" id="vDailyPrice" required />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Haftalik Fiyat</label>
                            <input type="number" step="0.01" class="form-control" id="vWeeklyPrice" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Aylik Fiyat</label>
                            <input type="number" step="0.01" class="form-control" id="vMonthlyPrice" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Yakit Tipi</label>
                            <select class="form-select" id="vFuelType" required>
                                <option value="Benzin">Benzin</option>
                                <option value="Dizel">Dizel</option>
                                <option value="LPG">LPG</option>
                                <option value="Elektrik">Elektrik</option>
                                <option value="Hibrit">Hibrit</option>
                            </select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Vites Tipi</label>
                            <select class="form-select" id="vTransmissionType" required>
                                <option value="Manuel">Manuel</option>
                                <option value="Otomatik">Otomatik</option>
                            </select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">KM</label>
                            <input type="number" class="form-control" id="vMileage" required />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Yolcu Kapasitesi</label>
                            <input type="number" class="form-control" id="vPassengerCapacity" value="5" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Bagaj Kapasitesi</label>
                            <input type="number" class="form-control" id="vLuggageCapacity" value="2" />
                        </div>
                        <div class="col-md-4 mb-3 d-none" id="vStatusDiv">
                            <label class="form-label">Durum</label>
                            <select class="form-select" id="vVehicleStatus">
                                <option value="Available">Musait</option>
                                <option value="Rented">Kirada</option>
                                <option value="Maintenance">Bakimda</option>
                                <option value="Damaged">Hasarli</option>
                            </select>
                        </div>
                        <div class="col-md-12 mb-3">
                            <label class="form-label">Resim URL</label>
                            <input type="text" class="form-control" id="vImageUrl" />
                        </div>
                        <div class="col-md-12 mb-3">
                            <label class="form-label">Aciklama</label>
                            <textarea class="form-control" id="vDescription" rows="2"></textarea>
                        </div>
                        <div class="col-md-6 mb-3 d-none" id="vActiveDiv">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="vIsActive" checked />
                                <label class="form-check-label">Aktif</label>
                            </div>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Kaydet</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    $(document).ready(function () {
        if (!isAdmin()) { window.location.href = "/"; return; }
        loadBrandOptions();
        loadVehicles();
    });

    function loadBrandOptions() {
        $.ajax({
            url: apiBaseUrl + "/Brands", type: "GET",
            success: function (data) {
                var html = "";
                $.each(data, function (i, b) { html += '<option value="' + b.id + '">' + b.name + '</option>'; });
                $("#vBrandId").html(html);
            }
        });
    }

    var statusMap = {"Available":"Musait","Rented":"Kirada","Maintenance":"Bakimda","Damaged":"Hasarli"};
    var statusColor = {"Available":"success","Rented":"warning","Maintenance":"info","Damaged":"danger"};

    function loadVehicles() {
        $.ajax({
            url: apiBaseUrl + "/Vehicles", type: "GET",
            success: function (data) {
                var html = "";
                $.each(data, function (i, v) {
                    html += "<tr><td>" + v.id + "</td><td>" + v.plate + "</td><td>" + v.brandName + "</td><td>" + v.model + "</td><td>" + v.year + "</td><td>" + v.color + "</td><td>" + v.fuelType + "</td><td>" + v.transmissionType + "</td><td>" + v.dailyPrice + " TL</td>";
                    html += '<td><span class="badge bg-' + (statusColor[v.vehicleStatus]||"secondary") + '">' + (statusMap[v.vehicleStatus]||v.vehicleStatus) + '</span></td>';
                    html += '<td><button class="btn btn-sm btn-warning me-1" onclick="editVehicle(' + v.id + ')"><i class="fas fa-edit"></i></button>';
                    html += '<button class="btn btn-sm btn-danger" onclick="deleteVehicle(' + v.id + ')"><i class="fas fa-trash"></i></button></td></tr>';
                });
                $("#vehicleList").html(html);
            }
        });
    }

    function openAddModal() {
        $("#vehicleModalTitle").text("Arac Ekle");
        $("#vehicleId").val("");
        $("#vehicleForm")[0].reset();
        $("#vStatusDiv, #vActiveDiv").addClass("d-none");
        new bootstrap.Modal(document.getElementById("vehicleModal")).show();
    }

    function editVehicle(id) {
        $.ajax({
            url: apiBaseUrl + "/Vehicles/" + id, type: "GET",
            success: function (v) {
                $("#vehicleModalTitle").text("Arac Duzenle");
                $("#vehicleId").val(v.id);
                $("#vPlate").val(v.plate);
                $("#vModel").val(v.model);
                $("#vBrandId").val(v.brandId);
                $("#vYear").val(v.year);
                $("#vColor").val(v.color);
                $("#vDailyPrice").val(v.dailyPrice);
                $("#vWeeklyPrice").val(v.weeklyPrice);
                $("#vMonthlyPrice").val(v.monthlyPrice);
                $("#vFuelType").val(v.fuelType);
                $("#vTransmissionType").val(v.transmissionType);
                $("#vMileage").val(v.mileage);
                $("#vPassengerCapacity").val(v.passengerCapacity);
                $("#vLuggageCapacity").val(v.luggageCapacity);
                $("#vImageUrl").val(v.imageUrl);
                $("#vDescription").val(v.description);
                $("#vVehicleStatus").val(v.vehicleStatus);
                $("#vIsActive").prop("checked", v.isActive);
                $("#vStatusDiv, #vActiveDiv").removeClass("d-none");
                new bootstrap.Modal(document.getElementById("vehicleModal")).show();
            }
        });
    }

    $("#vehicleForm").submit(function (e) {
        e.preventDefault();
        var id = $("#vehicleId").val();
        if (id) {
            $.ajax({
                url: apiBaseUrl + "/Vehicles/" + id, type: "PUT", contentType: "application/json",
                data: JSON.stringify({
                    plate: $("#vPlate").val(), model: $("#vModel").val(), year: parseInt($("#vYear").val()), color: $("#vColor").val(),
                    dailyPrice: parseFloat($("#vDailyPrice").val()), weeklyPrice: parseFloat($("#vWeeklyPrice").val()) || null,
                    monthlyPrice: parseFloat($("#vMonthlyPrice").val()) || null, description: $("#vDescription").val(),
                    imageUrl: $("#vImageUrl").val(), fuelType: $("#vFuelType").val(), transmissionType: $("#vTransmissionType").val(),
                    mileage: parseInt($("#vMileage").val()), passengerCapacity: parseInt($("#vPassengerCapacity").val()),
                    luggageCapacity: parseInt($("#vLuggageCapacity").val()), brandId: parseInt($("#vBrandId").val()),
                    vehicleStatus: $("#vVehicleStatus").val(), isActive: $("#vIsActive").is(":checked")
                }),
                success: function () { bootstrap.Modal.getInstance(document.getElementById("vehicleModal")).hide(); showAlert("Guncellendi.", "success"); loadVehicles(); },
                error: function () { showAlert("Hata.", "danger"); }
            });
        } else {
            $.ajax({
                url: apiBaseUrl + "/Vehicles", type: "POST", contentType: "application/json",
                data: JSON.stringify({
                    plate: $("#vPlate").val(), model: $("#vModel").val(), year: parseInt($("#vYear").val()), color: $("#vColor").val(),
                    dailyPrice: parseFloat($("#vDailyPrice").val()), weeklyPrice: parseFloat($("#vWeeklyPrice").val()) || null,
                    monthlyPrice: parseFloat($("#vMonthlyPrice").val()) || null, description: $("#vDescription").val(),
                    imageUrl: $("#vImageUrl").val(), fuelType: $("#vFuelType").val(), transmissionType: $("#vTransmissionType").val(),
                    mileage: parseInt($("#vMileage").val()), passengerCapacity: parseInt($("#vPassengerCapacity").val()),
                    luggageCapacity: parseInt($("#vLuggageCapacity").val()), brandId: parseInt($("#vBrandId").val())
                }),
                success: function () { bootstrap.Modal.getInstance(document.getElementById("vehicleModal")).hide(); showAlert("Eklendi.", "success"); loadVehicles(); },
                error: function () { showAlert("Hata.", "danger"); }
            });
        }
    });

    function deleteVehicle(id) {
        if (!confirm("Silmek istiyor musunuz?")) return;
        $.ajax({
            url: apiBaseUrl + "/Vehicles/" + id, type: "DELETE",
            success: function () { showAlert("Silindi.", "success"); loadVehicles(); },
            error: function () { showAlert("Hata.", "danger"); }
        });
    }
</script>
}
