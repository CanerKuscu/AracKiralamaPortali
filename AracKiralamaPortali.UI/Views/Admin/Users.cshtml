@{
    ViewData["Title"] = "Kullanici Yonetimi";
}

<h2><i class="fas fa-users"></i> Kullanici Yonetimi</h2>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr><th>ID</th><th>Ad Soyad</th><th>E-posta</th><th>Kullanici Adi</th><th>Telefon</th><th>TC Kimlik</th><th>Ehliyet</th><th>Rol</th><th>Durum</th><th>Kara Liste</th><th>Islem</th></tr>
        </thead>
        <tbody id="userList"></tbody>
    </table>
</div>

<div class="modal fade" id="editUserModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title">Kullanici Duzenle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="editUserForm">
                    <input type="hidden" id="euId" />
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Ad Soyad</label>
                            <input type="text" class="form-control" id="euFullName" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">E-posta</label>
                            <input type="email" class="form-control" id="euEmail" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Telefon</label>
                            <input type="text" class="form-control" id="euPhone" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">T.C. Kimlik No</label>
                            <input type="text" class="form-control" id="euTCKimlik" maxlength="11" />
                        </div>
                        <div class="col-md-12 mb-3">
                            <label class="form-label">Adres</label>
                            <textarea class="form-control" id="euAddress" rows="2"></textarea>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Ehliyet Sinifi</label>
                            <select class="form-select" id="euLicenseClass">
                                <option value="">Seciniz</option>
                                <option value="B">B</option>
                                <option value="B1">B1</option>
                                <option value="A">A</option>
                                <option value="C">C</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Ehliyet Verilis Tarihi</label>
                            <input type="date" class="form-control" id="euLicenseIssue" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="euIsActive" checked />
                                <label class="form-check-label">Aktif</label>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="euIsBlackListed" />
                                <label class="form-check-label text-danger">Kara Listede</label>
                            </div>
                        </div>
                        <div class="col-md-12 mb-3" id="blackListReasonDiv" style="display:none;">
                            <label class="form-label">Kara Liste Sebebi</label>
                            <textarea class="form-control" id="euBlackListReason" rows="2"></textarea>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-warning w-100">Guncelle</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="roleModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title">Rol Ata</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="roleForm">
                    <input type="hidden" id="roleUserId" />
                    <div class="mb-3">
                        <label class="form-label">Rol</label>
                        <select class="form-select" id="roleName" required>
                            <option value="User">User (Musteri)</option>
                            <option value="Employee">Employee (Calisan)</option>
                            <option value="Admin">Admin (Yonetici)</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-info w-100 text-white">Rol Ata</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    $(document).ready(function () {
        if (!isAdmin()) { window.location.href = "/"; return; }
        loadUsers();
        $("#euIsBlackListed").change(function () {
            $(this).is(":checked") ? $("#blackListReasonDiv").show() : $("#blackListReasonDiv").hide();
        });
    });

    function loadUsers() {
        $.ajax({
            url: apiBaseUrl + "/Auth/users", type: "GET",
            success: function (data) {
                var html = "";
                $.each(data, function (i, u) {
                    html += "<tr><td>" + u.id.substring(0, 8) + "...</td><td>" + u.fullName + "</td><td>" + u.email + "</td><td>" + u.userName + "</td><td>" + (u.phoneNumber || "-") + "</td>";
                    html += "<td>" + (u.tcKimlik || "-") + "</td>";
                    html += "<td>" + (u.licenseClass || "-") + "</td>";
                    html += "<td>" + u.roles.join(", ") + "</td>";
                    html += "<td>" + (u.isActive ? '<span class="badge bg-success">Aktif</span>' : '<span class="badge bg-danger">Pasif</span>') + "</td>";
                    html += "<td>" + (u.isBlackListed ? '<span class="badge bg-danger">Kara Liste</span>' : '<span class="badge bg-secondary">-</span>') + "</td>";
                    html += '<td><button class="btn btn-sm btn-warning me-1" onclick="editUser(\'' + u.id + '\')"><i class="fas fa-edit"></i></button>';
                    html += '<button class="btn btn-sm btn-info me-1 text-white" onclick="openRoleModal(\'' + u.id + '\')"><i class="fas fa-user-tag"></i></button>';
                    html += '<button class="btn btn-sm btn-danger" onclick="deleteUser(\'' + u.id + '\')"><i class="fas fa-trash"></i></button></td></tr>';
                });
                $("#userList").html(html);
            }
        });
    }

    function editUser(id) {
        $.ajax({
            url: apiBaseUrl + "/Auth/users/" + id, type: "GET",
            success: function (u) {
                $("#euId").val(u.id);
                $("#euFullName").val(u.fullName);
                $("#euEmail").val(u.email);
                $("#euPhone").val(u.phoneNumber);
                $("#euTCKimlik").val(u.tcKimlik);
                $("#euAddress").val(u.address);
                $("#euLicenseClass").val(u.licenseClass || "");
                $("#euLicenseIssue").val(u.licenseIssueDate ? u.licenseIssueDate.split("T")[0] : "");
                $("#euIsActive").prop("checked", u.isActive);
                $("#euIsBlackListed").prop("checked", u.isBlackListed);
                $("#euBlackListReason").val(u.blackListReason);
                u.isBlackListed ? $("#blackListReasonDiv").show() : $("#blackListReasonDiv").hide();
                new bootstrap.Modal(document.getElementById("editUserModal")).show();
            }
        });
    }

    $("#editUserForm").submit(function (e) {
        e.preventDefault();
        $.ajax({
            url: apiBaseUrl + "/Auth/users/" + $("#euId").val(), type: "PUT", contentType: "application/json",
            data: JSON.stringify({
                fullName: $("#euFullName").val(), email: $("#euEmail").val(), phoneNumber: $("#euPhone").val(),
                tcKimlik: $("#euTCKimlik").val(), address: $("#euAddress").val(),
                licenseClass: $("#euLicenseClass").val() || null,
                licenseIssueDate: $("#euLicenseIssue").val() || null,
                isActive: $("#euIsActive").is(":checked"),
                isBlackListed: $("#euIsBlackListed").is(":checked"),
                blackListReason: $("#euBlackListReason").val()
            }),
            success: function () { bootstrap.Modal.getInstance(document.getElementById("editUserModal")).hide(); showAlert("Guncellendi.", "success"); loadUsers(); },
            error: function () { showAlert("Hata.", "danger"); }
        });
    });

    function openRoleModal(userId) {
        $("#roleUserId").val(userId);
        new bootstrap.Modal(document.getElementById("roleModal")).show();
    }

    $("#roleForm").submit(function (e) {
        e.preventDefault();
        $.ajax({
            url: apiBaseUrl + "/Auth/roles/assign", type: "POST", contentType: "application/json",
            data: JSON.stringify({ userId: $("#roleUserId").val(), roleName: $("#roleName").val() }),
            success: function () { bootstrap.Modal.getInstance(document.getElementById("roleModal")).hide(); showAlert("Rol atandi.", "success"); loadUsers(); },
            error: function () { showAlert("Hata.", "danger"); }
        });
    });

    function deleteUser(id) {
        if (!confirm("Kullaniciyi silmek istiyor musunuz?")) return;
        $.ajax({
            url: apiBaseUrl + "/Auth/users/" + id, type: "DELETE",
            success: function () { showAlert("Silindi.", "success"); loadUsers(); },
            error: function () { showAlert("Hata.", "danger"); }
        });
    }
</script>
}
