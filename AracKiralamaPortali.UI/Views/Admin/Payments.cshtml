@{
    ViewData["Title"] = "Odeme Yonetimi";
}

<h2><i class="fas fa-credit-card"></i> Odeme Yonetimi</h2>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr><th>ID</th><th>Rezervasyon ID</th><th>Tutar</th><th>Odeme Yontemi</th><th>Odeme Tarihi</th><th>Durum</th><th>Islem</th></tr>
        </thead>
        <tbody id="paymentList"></tbody>
    </table>
</div>

<div class="modal fade" id="editPaymentModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title">Odeme Durumu Guncelle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="editPaymentForm">
                    <input type="hidden" id="epId" />
                    <div class="mb-3">
                        <label class="form-label">Durum</label>
                        <select class="form-select" id="epStatus" required>
                            <option value="Completed">Tamamlandi</option>
                            <option value="Pending">Beklemede</option>
                            <option value="Refunded">Iade Edildi</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-warning w-100">Guncelle</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    $(document).ready(function () {
        if (!isAdmin()) { window.location.href = "/"; return; }
        loadPayments();
    });

    function loadPayments() {
        $.ajax({
            url: apiBaseUrl + "/Payments", type: "GET",
            success: function (data) {
                var html = "";
                $.each(data, function (i, p) {
                    html += "<tr><td>" + p.id + "</td><td>" + p.reservationId + "</td><td>" + p.amount + " TL</td><td>" + p.paymentMethod + "</td>";
                    html += "<td>" + new Date(p.paymentDate).toLocaleDateString("tr-TR") + "</td>";
                    html += "<td>" + getPaymentBadge(p.status) + "</td>";
                    html += '<td><button class="btn btn-sm btn-warning me-1" onclick="editPayment(' + p.id + ',\'' + p.status + '\')"><i class="fas fa-edit"></i></button>';
                    html += '<button class="btn btn-sm btn-danger" onclick="deletePayment(' + p.id + ')"><i class="fas fa-trash"></i></button></td></tr>';
                });
                if (data.length === 0) html = '<tr><td colspan="7" class="text-center">Odeme bulunamadi.</td></tr>';
                $("#paymentList").html(html);
            }
        });
    }

    function getPaymentBadge(s) {
        if (s === "Completed") return '<span class="badge bg-success">Tamamlandi</span>';
        if (s === "Pending") return '<span class="badge bg-warning text-dark">Beklemede</span>';
        if (s === "Refunded") return '<span class="badge bg-info">Iade</span>';
        return '<span class="badge bg-secondary">' + s + '</span>';
    }

    function editPayment(id, status) {
        $("#epId").val(id);
        $("#epStatus").val(status);
        new bootstrap.Modal(document.getElementById("editPaymentModal")).show();
    }

    $("#editPaymentForm").submit(function (e) {
        e.preventDefault();
        $.ajax({
            url: apiBaseUrl + "/Payments/" + $("#epId").val(), type: "PUT", contentType: "application/json",
            data: JSON.stringify({ status: $("#epStatus").val() }),
            success: function () { bootstrap.Modal.getInstance(document.getElementById("editPaymentModal")).hide(); showAlert("Guncellendi.", "success"); loadPayments(); },
            error: function () { showAlert("Hata.", "danger"); }
        });
    });

    function deletePayment(id) {
        if (!confirm("Silmek istiyor musunuz?")) return;
        $.ajax({
            url: apiBaseUrl + "/Payments/" + id, type: "DELETE",
            success: function () { showAlert("Silindi.", "success"); loadPayments(); },
            error: function () { showAlert("Hata.", "danger"); }
        });
    }
</script>
}
