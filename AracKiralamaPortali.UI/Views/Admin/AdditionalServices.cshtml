@{
    ViewData["Title"] = "Ek Hizmet Yonetimi";
}

<h2><i class="fas fa-concierge-bell"></i> Ek Hizmet Yonetimi</h2>

<button class="btn btn-primary mb-3" onclick="openAddModal()"><i class="fas fa-plus"></i> Yeni Hizmet</button>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr><th>ID</th><th>Hizmet Adi</th><th>Aciklama</th><th>Fiyat (TL/Gun)</th><th>Durum</th><th>Islem</th></tr>
        </thead>
        <tbody id="serviceList"></tbody>
    </table>
</div>

<div class="modal fade" id="serviceModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="serviceModalTitle"></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="serviceForm">
                    <input type="hidden" id="serviceId" />
                    <div class="mb-3">
                        <label class="form-label">Hizmet Adi</label>
                        <input type="text" class="form-control" id="sName" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Aciklama</label>
                        <textarea class="form-control" id="sDescription" rows="2"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Gunluk Fiyat (TL)</label>
                        <input type="number" step="0.01" class="form-control" id="sPrice" required />
                    </div>
                    <div class="mb-3 d-none" id="sActiveDiv">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="sIsActive" checked />
                            <label class="form-check-label">Aktif</label>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Kaydet</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    $(document).ready(function () {
        if (!isAdmin()) { window.location.href = "/"; return; }
        loadServices();
    });

    function loadServices() {
        $.ajax({
            url: apiBaseUrl + "/AdditionalServices", type: "GET",
            success: function (data) {
                var html = "";
                $.each(data, function (i, s) {
                    html += "<tr><td>" + s.id + "</td><td>" + s.name + "</td><td>" + (s.description || "-") + "</td><td>" + s.price + " TL</td>";
                    html += "<td>" + (s.isActive ? '<span class="badge bg-success">Aktif</span>' : '<span class="badge bg-danger">Pasif</span>') + "</td>";
                    html += '<td><button class="btn btn-sm btn-warning me-1" onclick="editService(' + s.id + ')"><i class="fas fa-edit"></i></button>';
                    html += '<button class="btn btn-sm btn-danger" onclick="deleteService(' + s.id + ')"><i class="fas fa-trash"></i></button></td></tr>';
                });
                if (!data.length) html = '<tr><td colspan="6" class="text-center">Hizmet bulunamadi.</td></tr>';
                $("#serviceList").html(html);
            }
        });
    }

    function openAddModal() {
        $("#serviceModalTitle").text("Yeni Hizmet Ekle");
        $("#serviceId").val("");
        $("#serviceForm")[0].reset();
        $("#sActiveDiv").addClass("d-none");
        new bootstrap.Modal(document.getElementById("serviceModal")).show();
    }

    function editService(id) {
        $.ajax({
            url: apiBaseUrl + "/AdditionalServices/" + id, type: "GET",
            success: function (s) {
                $("#serviceModalTitle").text("Hizmet Duzenle");
                $("#serviceId").val(s.id);
                $("#sName").val(s.name);
                $("#sDescription").val(s.description);
                $("#sPrice").val(s.price);
                $("#sIsActive").prop("checked", s.isActive);
                $("#sActiveDiv").removeClass("d-none");
                new bootstrap.Modal(document.getElementById("serviceModal")).show();
            }
        });
    }

    $("#serviceForm").submit(function (e) {
        e.preventDefault();
        var id = $("#serviceId").val();
        if (id) {
            $.ajax({
                url: apiBaseUrl + "/AdditionalServices/" + id, type: "PUT", contentType: "application/json",
                data: JSON.stringify({ name: $("#sName").val(), description: $("#sDescription").val(), price: parseFloat($("#sPrice").val()), isActive: $("#sIsActive").is(":checked") }),
                success: function () { bootstrap.Modal.getInstance(document.getElementById("serviceModal")).hide(); showAlert("Guncellendi.", "success"); loadServices(); },
                error: function () { showAlert("Hata.", "danger"); }
            });
        } else {
            $.ajax({
                url: apiBaseUrl + "/AdditionalServices", type: "POST", contentType: "application/json",
                data: JSON.stringify({ name: $("#sName").val(), description: $("#sDescription").val(), price: parseFloat($("#sPrice").val()) }),
                success: function () { bootstrap.Modal.getInstance(document.getElementById("serviceModal")).hide(); showAlert("Eklendi.", "success"); loadServices(); },
                error: function () { showAlert("Hata.", "danger"); }
            });
        }
    });

    function deleteService(id) {
        if (!confirm("Silmek istiyor musunuz?")) return;
        $.ajax({
            url: apiBaseUrl + "/AdditionalServices/" + id, type: "DELETE",
            success: function () { showAlert("Silindi.", "success"); loadServices(); },
            error: function () { showAlert("Hata.", "danger"); }
        });
    }
</script>
}
