@{
    ViewData["Title"] = "Raporlar";
}

<h2><i class="fas fa-chart-bar"></i> Raporlar</h2>

<div class="row mb-4">
    <div class="col-md-2">
        <div class="card text-white bg-primary shadow">
            <div class="card-body text-center">
                <h6>Toplam Arac</h6>
                <h3 id="totalVehicles">0</h3>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card text-white bg-success shadow">
            <div class="card-body text-center">
                <h6>Musait Arac</h6>
                <h3 id="availableVehicles">0</h3>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card text-white bg-info shadow">
            <div class="card-body text-center">
                <h6>Toplam Rez.</h6>
                <h3 id="totalReservations">0</h3>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card text-white bg-warning shadow">
            <div class="card-body text-center">
                <h6>Aktif Rez.</h6>
                <h3 id="activeReservations">0</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-dark shadow">
            <div class="card-body text-center">
                <h6>Toplam Gelir</h6>
                <h3 id="totalRevenue">0 TL</h3>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card shadow mb-4">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0"><i class="fas fa-money-bill-wave"></i> Aylik Gelir Raporu</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Yil</label>
                    <input type="number" class="form-control" id="revenueYear" value="2025" style="width:120px;display:inline-block;" />
                    <button class="btn btn-primary btn-sm" onclick="loadRevenue()">Getir</button>
                </div>
                <table class="table table-sm">
                    <thead><tr><th>Ay</th><th>Gelir (TL)</th></tr></thead>
                    <tbody id="revenueList"></tbody>
                    <tfoot><tr class="table-dark"><th>TOPLAM</th><th id="grandTotal">0 TL</th></tr></tfoot>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card shadow mb-4">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0"><i class="fas fa-star"></i> En Populer Araclar</h5>
            </div>
            <div class="card-body">
                <table class="table table-sm">
                    <thead><tr><th>#</th><th>Arac</th><th>Kiralama Sayisi</th><th>Toplam Gelir</th></tr></thead>
                    <tbody id="popularList"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var months = ["","Ocak","Subat","Mart","Nisan","Mayis","Haziran","Temmuz","Agustos","Eylul","Ekim","Kasim","Aralik"];

    $(document).ready(function () {
        if (!isAdmin()) { window.location.href = "/"; return; }
        loadSummary();
        loadRevenue();
        loadPopular();
    });

    function loadSummary() {
        $.ajax({
            url: apiBaseUrl + "/Reports/summary", type: "GET",
            success: function (d) {
                $("#totalVehicles").text(d.totalVehicles);
                $("#availableVehicles").text(d.availableVehicles);
                $("#totalReservations").text(d.totalReservations);
                $("#activeReservations").text(d.activeReservations);
                $("#totalRevenue").text(d.totalRevenue + " TL");
            }
        });
    }

    function loadRevenue() {
        var year = $("#revenueYear").val();
        $.ajax({
            url: apiBaseUrl + "/Reports/revenue?year=" + year, type: "GET",
            success: function (d) {
                var html = "";
                $.each(d.monthlyRevenue, function (i, m) {
                    html += "<tr><td>" + months[m.month] + "</td><td>" + m.total + " TL</td></tr>";
                });
                $("#revenueList").html(html);
                $("#grandTotal").text(d.grandTotal + " TL");
            }
        });
    }

    function loadPopular() {
        $.ajax({
            url: apiBaseUrl + "/Reports/popular-vehicles", type: "GET",
            success: function (data) {
                var html = "";
                $.each(data, function (i, v) {
                    html += "<tr><td>" + (i + 1) + "</td><td>" + v.brand + " " + v.model + " (" + v.plate + ")</td><td>" + v.rentalCount + "</td><td>" + v.totalRevenue + " TL</td></tr>";
                });
                if (!data.length) html = '<tr><td colspan="4" class="text-center">Veri bulunamadi.</td></tr>';
                $("#popularList").html(html);
            }
        });
    }
</script>
}
