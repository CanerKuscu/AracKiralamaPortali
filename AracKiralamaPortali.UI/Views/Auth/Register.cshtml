@{
    ViewData["Title"] = "Kayit Ol";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow">
            <div class="card-header bg-success text-white">
                <h4 class="mb-0"><i class="fas fa-user-plus"></i> Kayit Ol</h4>
            </div>
            <div class="card-body">
                <form id="registerForm">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Ad Soyad</label>
                            <input type="text" class="form-control" id="fullName" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">E-posta</label>
                            <input type="email" class="form-control" id="email" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Kullanici Adi</label>
                            <input type="text" class="form-control" id="userName" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Telefon</label>
                            <input type="text" class="form-control" id="phoneNumber" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">T.C. Kimlik No</label>
                            <input type="text" class="form-control" id="tcKimlik" maxlength="11" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Dogum Tarihi</label>
                            <input type="date" class="form-control" id="birthDate" max="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Ehliyet Sinifi</label>
                            <select class="form-select" id="licenseClass">
                                <option value="">Seciniz</option>
                                <option value="B">B</option>
                                <option value="B1">B1</option>
                                <option value="A">A</option>
                                <option value="C">C</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Ehliyet Verilis Tarihi</label>
                            <input type="date" class="form-control" id="licenseIssueDate" max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Kayýt Türü</label>
                            <select class="form-select" id="role" required>
                                <option value="User">Normal Üye</option>
                                <option value="CarOwner">Araç Sahibi</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Sifre</label>
                            <input type="password" class="form-control" id="password" required minlength="6" />
                        </div>
                        <div class="col-md-12 mb-3">
                            <label class="form-label">Adres</label>
                            <textarea class="form-control" id="address" rows="2"></textarea>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-success w-100">Kayit Ol</button>
                </form>
                <div class="mt-3 text-center">
                    Hesabiniz var mi? <a asp-controller="Auth" asp-action="Login">Giris Yap</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function validateRegisterForm() {
        var form = document.getElementById("registerForm");
        if (!form.checkValidity()) {
            form.reportValidity();
            return false;
        }

        var licenseIssueDate = $("#licenseIssueDate").val();
        if (licenseIssueDate) {
            var selectedDate = new Date(licenseIssueDate + "T00:00:00");
            var today = new Date();
            today.setHours(0, 0, 0, 0);

            if (selectedDate > today) {
                showAlert("Ehliyet verilis tarihi bugunden ileri bir tarih olamaz.", "danger");
                return false;
            }
        }

        var birthDate = $("#birthDate").val();
        if (birthDate) {
            var selectedBirthDate = new Date(birthDate + "T00:00:00");
            var todayForBirthDate = new Date();
            todayForBirthDate.setHours(0, 0, 0, 0);

            if (selectedBirthDate > todayForBirthDate) {
                showAlert("Dogum tarihi bugunden ileri bir tarih olamaz.", "danger");
                return false;
            }
        }

        return true;
    }

    $("#registerForm").submit(function (e) {
        e.preventDefault();

        if (!validateRegisterForm()) {
            return;
        }

        $.ajax({
            url: apiBaseUrl + "/Auth/register",
            type: "POST",
            contentType: "application/json",
            data: JSON.stringify({
                fullName: $("#fullName").val(),
                email: $("#email").val(),
                userName: $("#userName").val(),
                phoneNumber: $("#phoneNumber").val(),
                password: $("#password").val(),
                tcKimlik: $("#tcKimlik").val(),
                birthDate: $("#birthDate").val() || null,
                address: $("#address").val(),
                licenseClass: $("#licenseClass").val() || null,
                licenseIssueDate: $("#licenseIssueDate").val() || null,
                role: $("#role").val()
            }),
            success: function () {
                showAlert("Kayýt baţarýlý! Giriţ yapabilirsiniz.", "success");
                setTimeout(function () { window.location.href = "/Auth/Login"; }, 1500);
            },
            error: function (xhr) {
                var msg = "Kayýt baţarýsýz.";
                var data = xhr.responseJSON;

                if (data) {
                    if (Array.isArray(data)) {
                        msg = data
                            .map(function (e) { return e.description || e.code || e; })
                            .join("<br/>");
                    } else if (data.message) {
                        msg = data.message;
                    } else if (data.title) {
                        msg = data.title;
                    }

                    if (data.errors) {
                        var validationMessages = Object.keys(data.errors)
                            .flatMap(function (k) { return data.errors[k]; });
                        if (validationMessages.length > 0)
                            msg = validationMessages.join("<br/>");
                    }
                } else if (xhr.responseText) {
                    msg = xhr.responseText;
                }

                showAlert(msg, "danger");
            }
        });
    });
</script>
}
